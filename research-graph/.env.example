# confgate research-graph environment — COPY to `.env` and fill in real secrets.
# `.env` is gitignored (see ../.gitignore). NEVER commit real passwords.

# --- confgate's own standalone graph (we read+write) ---
NEO4J_BOLT_URL=bolt://localhost:7689
NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme-generate-a-fresh-one

# --- link-forge substrate (READ-ONLY to us; do not write) ---
LINK_FORGE_BOLT_URL=bolt://localhost:7687
LINK_FORGE_USER=neo4j
LINK_FORGE_PASSWORD=link_forge_dev

# --- link-forge sweep provenance (read-only) ---
# admit.py reads the dated sweep JSON research-sweep.ts writes, falling back to queue.db.
# Confirm the real LINK_FORGE_SWEEP_DIR path at Phase 1 build time (open-Q4).
LINK_FORGE_QUEUE_DB=~/link-forge/data/queue.db
LINK_FORGE_SWEEP_DIR=~/link-forge/data/sweeps
